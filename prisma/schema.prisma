generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== Enums ====================

enum UserRole {
  ADMIN
  PROJECT_LEAD
  MEMBER
}

enum ProjectPhase {
  SCHEME
  PRELIMINARY
  CONSTRUCTION
  COMPLETION
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ==================== Models ====================

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  password       String
  name           String
  role           UserRole @default(MEMBER)
  phone          String?
  department     String?
  position       String?
  avatar         String?
  weeklyCapacity Decimal  @default(40) // 每周标准工时，用于计算饱和度
  isActive       Boolean  @default(true)
  idNumber       String?  // 身份证号（仅管理员可见）
  specialty      String?  // 专业方向（建筑/结构/给排水/暖通/电气等）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ledProjects          Project[]            @relation("ProjectLead")
  projectMembers       ProjectMember[]
  milestones           Milestone[]          @relation("MilestoneAssignee")
  projectNotes         ProjectNote[]
  workLogs             WorkLog[]
  confirmedWorkLogs    WorkLog[]            @relation("WorkLogConfirmer")
  createdCategories    NonProjectCategory[]
  assignedTasks        Task[]               @relation("TaskAssignee")
  createdTasks         Task[]               @relation("TaskCreator")
  taskStatusLogs       TaskStatusLog[]
  notifications        Notification[]
  appeals              Appeal[]             @relation("AppealAuthor")
  resolvedAppeals      Appeal[]             @relation("AppealResolver")
  auditLogs            AuditLog[]

  @@map("users")
}

model Project {
  id             String        @id @default(cuid())
  name           String
  contractNo     String?       @unique
  contractAmount Decimal?
  clientName     String
  clientContact  String?
  projectType    String?
  phase          ProjectPhase  @default(SCHEME)
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?
  leadId         String
  description    String?
  address        String?
  buildingArea   Decimal?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lead     User            @relation("ProjectLead", fields: [leadId], references: [id])
  members  ProjectMember[]
  milestones Milestone[]
  notes    ProjectNote[]
  workLogs WorkLog[]
  tasks    Task[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model Milestone {
  id          String       @id @default(cuid())
  projectId   String
  phase       ProjectPhase
  name        String
  description String?
  dueDate     DateTime
  completedAt DateTime?
  isCompleted Boolean      @default(false)
  assigneeId  String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("MilestoneAssignee", fields: [assigneeId], references: [id])
  tasks    Task[]

  @@index([projectId])
  @@index([dueDate])
  @@map("milestones")
}

model ProjectNote {
  id             String   @id @default(cuid())
  projectId      String
  authorId       String
  content        String
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@map("project_notes")
}

model WorkLog {
  id                   String    @id @default(cuid())
  userId               String
  projectId            String?
  taskId               String?
  date                 DateTime
  hours                Decimal
  content              String
  category             String?
  nonProjectCategoryId String?
  confirmedAt          DateTime?
  confirmedById        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task               Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  nonProjectCategory NonProjectCategory? @relation(fields: [nonProjectCategoryId], references: [id])
  confirmedBy        User?               @relation("WorkLogConfirmer", fields: [confirmedById], references: [id])

  @@index([userId, date])
  @@index([projectId])
  @@index([taskId])
  @@map("work_logs")
}

model NonProjectCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  createdById String
  createdAt   DateTime @default(now())

  createdBy User      @relation(fields: [createdById], references: [id])
  workLogs  WorkLog[]

  @@map("non_project_categories")
}

// ==================== Phase 1：任务管理 ====================

/// 任务（细粒度执行单元）
/// status 用 String 而非 enum，避免每次扩展都需要 schema migration
/// 取值约定：pending | in_progress | done | overdue
/// priority 取值约定：normal | urgent
model Task {
  id              String    @id @default(cuid())
  projectId       String?
  milestoneId     String?
  name            String
  description     String?
  specialty       String?   // 责任专业（建筑/结构/给排水/暖通/电气等），与 User.specialty 字典对齐
  assigneeId      String
  createdById     String
  estimatedHours  Decimal   // 预估工时（小时，最小 0.5）
  priority        String    @default("normal")
  isInsertion     Boolean   @default(false)
  insertionReason String?
  plannedStart    DateTime
  plannedEnd      DateTime
  status          String    @default("pending")
  confirmedAt     DateTime? // 员工每日确认（Phase 2 启用）
  completedAt     DateTime? // 员工标记完成
  pmConfirmedAt   DateTime? // PM 确认完成
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project    Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestone  Milestone?      @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignee   User            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy  User            @relation("TaskCreator", fields: [createdById], references: [id])
  workLogs   WorkLog[]
  statusLogs TaskStatusLog[]

  @@index([assigneeId, status])
  @@index([projectId])
  @@index([plannedEnd])
  @@map("tasks")
}

// ==================== Phase 2：通知 + 申诉 ====================

/// 站内通知
/// type 取值约定：task_overdue | not_confirmed_3d | overload | repeated_insertion | appeal_update | task_done_pm_review | feishu
/// payload 是 JSON，按 type 不同装载相关字段（taskId/userId/scoreId 等）
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  payload   Json?
  /// 关联实体（用于点击跳转）：task | appeal | worklog | project | null
  linkType  String?
  linkId    String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// 申诉（员工对任务状态 / 工时 / 评分等数据有异议时提交）
/// targetType 取值：task | worklog | score | task_status
/// status 取值：pending | accepted | rejected | resolved
model Appeal {
  id           String    @id @default(cuid())
  authorId     String
  targetType   String
  targetId     String
  content      String
  status       String    @default("pending")
  resolvedById String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author     User  @relation("AppealAuthor", fields: [authorId], references: [id])
  resolvedBy User? @relation("AppealResolver", fields: [resolvedById], references: [id])

  @@index([authorId])
  @@index([status])
  @@map("appeals")
}

/// 审计日志：ADMIN/PM 对敏感数据的修改全部留痕
/// action 取值约定：user_anonymize | user_role_change | user_password_reset
///                  | project_delete | task_force_change | worklog_admin_edit
///                  | appeal_resolve | credentials_setup | data_purge | misc
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

/// 任务状态变更历史（插队 / 延期 / 完成 / PM 处理措施全部留痕）
model TaskStatusLog {
  id          String   @id @default(cuid())
  taskId      String
  fromStatus  String?
  toStatus    String
  reason      String?  // 延期原因 / 插队原因 / PM 处理措施
  changedById String
  changedAt   DateTime @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User @relation(fields: [changedById], references: [id])

  @@index([taskId])
  @@index([changedAt])
  @@map("task_status_logs")
}
