generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== Enums ====================

enum UserRole {
  ADMIN
  PROJECT_LEAD
  MEMBER
}

enum ProjectPhase {
  SCHEME
  PRELIMINARY
  CONSTRUCTION
  COMPLETION
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ==================== Models ====================

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  password       String
  name           String
  role           UserRole @default(MEMBER)
  phone          String?
  department     String?
  position       String?
  avatar         String?
  weeklyCapacity Decimal  @default(40) // 每周标准工时，用于计算饱和度
  isActive       Boolean  @default(true)
  idNumber       String?  // 身份证号（仅管理员可见）
  specialty      String?  // 专业方向（建筑/结构/给排水/暖通/电气等）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ledProjects          Project[]            @relation("ProjectLead")
  projectMembers       ProjectMember[]
  milestones           Milestone[]          @relation("MilestoneAssignee")
  projectNotes         ProjectNote[]
  workLogs             WorkLog[]
  confirmedWorkLogs    WorkLog[]            @relation("WorkLogConfirmer")
  createdCategories    NonProjectCategory[]

  @@map("users")
}

model Project {
  id             String        @id @default(cuid())
  name           String
  contractNo     String?       @unique
  contractAmount Decimal?
  clientName     String
  clientContact  String?
  projectType    String?
  phase          ProjectPhase  @default(SCHEME)
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?
  leadId         String
  description    String?
  address        String?
  buildingArea   Decimal?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lead     User            @relation("ProjectLead", fields: [leadId], references: [id])
  members  ProjectMember[]
  milestones Milestone[]
  notes    ProjectNote[]
  workLogs WorkLog[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model Milestone {
  id          String       @id @default(cuid())
  projectId   String
  phase       ProjectPhase
  name        String
  description String?
  dueDate     DateTime
  completedAt DateTime?
  isCompleted Boolean      @default(false)
  assigneeId  String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("MilestoneAssignee", fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([dueDate])
  @@map("milestones")
}

model ProjectNote {
  id             String   @id @default(cuid())
  projectId      String
  authorId       String
  content        String
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@map("project_notes")
}

model WorkLog {
  id                   String    @id @default(cuid())
  userId               String
  projectId            String?
  date                 DateTime
  hours                Decimal
  content              String
  category             String?
  nonProjectCategoryId String?
  confirmedAt          DateTime?
  confirmedById        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  nonProjectCategory NonProjectCategory? @relation(fields: [nonProjectCategoryId], references: [id])
  confirmedBy        User?               @relation("WorkLogConfirmer", fields: [confirmedById], references: [id])

  @@index([userId, date])
  @@index([projectId])
  @@map("work_logs")
}

model NonProjectCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  createdById String
  createdAt   DateTime @default(now())

  createdBy User      @relation(fields: [createdById], references: [id])
  workLogs  WorkLog[]

  @@map("non_project_categories")
}
